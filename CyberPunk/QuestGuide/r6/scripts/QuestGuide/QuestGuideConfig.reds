// QuestGuide - configuração do usuário
// Troque a tecla abaixo e recarregue os scripts (Ctrl+R no console redscript ou reinicie o jogo).
// Valores possíveis: EInputKey.IK_<tecla>, ex.: IK_U, IK_J, IK_F7, IK_Home
module QuestGuide

public class QuestGuideConfig {
  public static func Key() -> EInputKey {
    return EInputKey.IK_U;
  }
}
